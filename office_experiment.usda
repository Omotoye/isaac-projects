                custom uint inputs:width = 400
            }

            over "back_2d_lidar_render_product"
            {
                custom rel inputs:cameraPrim = </World/Nova_Carter_ROS_1/chassis_link/sensors/rear_RPLidar/RPLidar_S2E>
                custom bool inputs:enabled = 0
            }

            over "front_3d_lidar_render_product"
            {
                custom rel inputs:cameraPrim = </World/Nova_Carter_ROS_1/chassis_link/sensors/XT_32/PandarXT_32_10hz>
                custom bool inputs:enabled = 0
            }
        }

        over "transform_tree_odometry"
        {
            over "node_namespace"
            {
                custom string inputs:value = "carter1"
            }

            over "isaac_compute_odometry_node"
            {
                custom rel inputs:chassisPrim = </World/Nova_Carter_ROS_1/chassis_link>
            }

            over "tf_tree_base_link_to_chassis"
            {
                custom rel inputs:parentPrim = </World/Nova_Carter_ROS_1/chassis_link/base_link>
                custom rel inputs:targetPrims = </World/Nova_Carter_ROS_1/chassis_link>
            }

            over "tf_tree_base_link_to_sensors"
            {
                custom rel inputs:parentPrim = </World/Nova_Carter_ROS_1/chassis_link/base_link>
                custom rel inputs:targetPrims = [
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/front_hawk/right/camera_right>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/front_hawk/left/camera_left>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/left_hawk/right/camera_right>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/left_hawk/left/camera_left>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/right_hawk/right/camera_right>,
