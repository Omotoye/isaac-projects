            {
                custom string inputs:nodeNamespace = "carter1"
            }

            over "left_camera_render_product"
            {
                custom rel inputs:cameraPrim = </World/Nova_Carter_ROS_1/chassis_link/sensors/right_hawk/left/camera_left>
            }

            over "right_camera_render_product"
            {
                custom rel inputs:cameraPrim = </World/Nova_Carter_ROS_1/chassis_link/sensors/right_hawk/right/camera_right>
            }

            over "isaac_read_imu_node"
            {
                custom rel inputs:imuPrim = </World/Nova_Carter_ROS_1/chassis_link/sensors/right_hawk/Imu/Imu_Sensor>
            }

            over "camera_namespace"
            {
                custom string inputs:value = "/carter1/right_stereo_camera"
            }
        }

        over "left_hawk"
        {
            over "right_camera_namespace"
            {
                custom string inputs:value = "carter1/left_stereo_camera/right_rgb"
            }

            over "left_camera_namespace"
