                    </World/Nova_Carter_ROS_1/chassis_link/sensors/right_hawk/Imu/Imu_Sensor>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/back_hawk/Imu/Imu_Sensor>,
                ]
            }
        }

        over "chassis_link"
        {
            over "sensors"
            {
                over "front_hawk"
                {
                    over "Imu"
