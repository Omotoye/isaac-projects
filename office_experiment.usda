                    </World/Nova_Carter_ROS_1/chassis_link/sensors/back_hawk/left/camera_left>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/front_RPLidar/RPLidar_S2E>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/rear_RPLidar/RPLidar_S2E>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/XT_32/PandarXT_32_10hz>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/front_hawk>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/front_hawk/left>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/front_hawk/right>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/left_hawk>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/left_hawk/left>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/left_hawk/right>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/right_hawk>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/right_hawk/left>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/right_hawk/right>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/back_hawk>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/back_hawk/left>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/back_hawk/right>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/front_owl>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/front_owl/camera>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/left_owl>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/left_owl/camera>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/right_owl>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/right_owl/camera>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/back_owl>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/back_owl/camera>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/chassis_imu/Imu_Sensor>,
                    </World/Nova_Carter_ROS_1/chassis_link/sensors/front_hawk/Imu/Imu_Sensor>,
