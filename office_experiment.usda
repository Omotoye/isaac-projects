            }

            over "ros2_publish_imu"
            {
                custom string inputs:nodeNamespace = "carter1"
            }

            over "left_camera_render_product"
            {
                custom rel inputs:cameraPrim = </World/Nova_Carter_ROS_1/chassis_link/sensors/left_hawk/left/camera_left>
            }

            over "right_camera_render_product"
            {
                custom rel inputs:cameraPrim = </World/Nova_Carter_ROS_1/chassis_link/sensors/left_hawk/right/camera_right>
            }

            over "isaac_read_imu_node"
            {
                custom rel inputs:imuPrim = </World/Nova_Carter_ROS_1/chassis_link/sensors/left_hawk/Imu/Imu_Sensor>
            }

            over "camera_namespace"
            {
                custom string inputs:value = "/carter1/left_stereo_camera"
            }
        }

        over "back_hawk"
        {
            over "ros2_publish_imu"
            {
                custom string inputs:nodeNamespace = "carter1"
            }

            over "right_camera_namespace"
            {
                custom string inputs:value = "carter1/rear_stereo_camera/right_rgb"
            }

            over "left_camera_namespace"
            {
                custom string inputs:value = "carter1/rear_stereo_camera/left_rgb"
            }

            over "left_camera_render_product"
            {
                custom rel inputs:cameraPrim = </World/Nova_Carter_ROS_1/chassis_link/sensors/back_hawk/left/camera_left>
            }

            over "right_camera_render_product"
            {
                custom rel inputs:cameraPrim = </World/Nova_Carter_ROS_1/chassis_link/sensors/back_hawk/right/camera_right>
            }

            over "isaac_read_imu_node"
            {
                custom rel inputs:imuPrim = </World/Nova_Carter_ROS_1/chassis_link/sensors/back_hawk/Imu/Imu_Sensor>
            }

            over "camera_namespace"
            {
                custom string inputs:value = "/carter1/back_stereo_camera"
            }
        }

        over "ros_lidars"
        {
            over "node_namespace"
            {
                custom string inputs:value = "carter1"
            }

            over "publish_front_2d_lidar_scan"
            {
                custom bool inputs:enabled = 1
                custom bool inputs:fullScan
            }

            over "publish_back_2d_lidar_scan"
            {
