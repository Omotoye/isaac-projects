    def "Nova_Carter_ROS_2" (
        prepend payload = @https://omniverse-content-production.s3-us-west-2.amazonaws.com/Assets/Isaac/5.1/Isaac/Samples/ROS2/Robots/Nova_Carter_ROS.usd@
    )
    {
        quatf xformOp:orient = (6.123234e-17, 0, 0, 1)
        double3 xformOp:translate = (4, -1, 0)

        over "differential_drive"
        {
