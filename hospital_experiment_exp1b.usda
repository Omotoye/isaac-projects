            {
                custom rel inputs:cameraPrim = </World/Nova_Carter_ROS_1/chassis_link/sensors/front_owl/camera>
            }

            over "namespace"
            {
                custom string inputs:value = "/carter1/right_fisheye_camera/left"
            }
        }

        over "chassis_imu"
        {
            over "isaac_read_imu_node"
            {
                custom rel inputs:imuPrim = </World/Nova_Carter_ROS_1/chassis_link/sensors/chassis_imu/Imu_Sensor>
            }

            over "node_namespace"
            {
                custom string inputs:value = "carter1"
            }
        }

        over "chassis_link"
        {
            over "sensors"
            {
                over "front_hawk"
                {
                    over "Imu"
                    {
                        over "Imu_Sensor"
                        {
                            custom string isaac:nameOverride (
                                displayName = "Name Override"
                                doc = "Name override for prim lookup in base name search"
                            )
                        }
                    }
                }

                over "left_hawk"
                {
                    over "Imu"
                    {
                        over "Imu_Sensor"
                        {
                            custom string isaac:nameOverride (
                                displayName = "Name Override"
                                doc = "Name override for prim lookup in base name search"
                            )
                        }
                    }
                }

                over "right_hawk"
                {
                    over "Imu"
                    {
                        over "Imu_Sensor"
                        {
                            custom string isaac:nameOverride (
                                displayName = "Name Override"
                                doc = "Name override for prim lookup in base name search"
                            )
                        }
                    }
                }

                over "chassis_imu"
                {
                    over "Imu_Sensor"
                    {
                        custom string isaac:nameOverride (
                            displayName = "Name Override"
                            doc = "Name override for prim lookup in base name search"
                        )
                    }
                }

                over "back_hawk"
                {
